{
"model": {
        "type": "select",
        "property": "custom_model_data",
        "fallback": {
            "type": "model",
            "model": "item/activator_rail"
        },
        "cases": [
            {
                "when": "middle",
                "model": {
                    "type": "model",
                    "model": "block/activator_rail_middle"
                }
            },
            {
                "when": "bricks",
                "model": {
                    "type": "model",
                    "model": "block/activator_rail_bricks"
                }
            },
            {
                "when": "bricksL",
                "model": {
                    "type": "model",
                    "model": "block/activator_rail_bricksL"
                }
            },
            {
                "when": "yellow_concrete",
                "model": {
                    "type": "model",
                    "model": "block/activator_rail_yellow_concrete"
                }
            }
        ]
    }
}