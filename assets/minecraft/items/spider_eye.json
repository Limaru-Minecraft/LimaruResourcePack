{
    "model": {
        "type": "select",
        "property": "custom_model_data",
        "fallback": {
            "type": "model",
            "model": "item/spider_eye"
        },
        "cases": [
            {
                "when": "pk_ferry_a",
                "model": {
                    "type": "model",
                    "model": "item/boatmodel/transpark/pk_ferry_a"
                }
            },
            {
                "when": "pk_metrotram_c_passengercar",
                "model": {
                    "type": "model",
                    "model": "item/trainmodel/transpark/pk_metrotram_c_passengercar"
                }
            },
            {
                "when": "pk_metrotram_c_drivercar",
                "model": {
                    "type": "model",
                    "model": "item/trainmodel/transpark/pk_metrotram_c_drivercar"
                }
            },
            {
                "when": "pk_metrotram_c_accordian",
                "model": {
                    "type": "model",
                    "model": "item/trainmodel/transpark/pk_metrotram_c_accordian"
                }
            },
            {
                "when": "pk_metrotram_c_bogie",
                "model": {
                    "type": "model",
                    "model": "item/trainmodel/transpark/pk_metrotram_c_bogie"
                }
            },
            {
                "when": "pk_metrotram_c_pantograph",
                "model": {
                    "type": "model",
                    "model": "item/trainmodel/transpark/pk_metrotram_c_pantograph"
                }
            },
            {
                "when": "pk_metrotram_c_utility",
                "model": {
                    "type": "model",
                    "model": "item/trainmodel/transpark/pk_metrotram_c_utility"
                }
            }
        ]
    }
}